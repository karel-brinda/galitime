.PHONY: all clean run_plain run_gtime check_gtime

SHELL := /usr/bin/env bash
.SHELLFLAGS := -eo pipefail -c

# CLI under test.
GALITIME := ../../galitime

# Command that terminates itself with SIGKILL.
# On Unix, this is expected to surface as exit status 137.
CMD := python3 -c 'import os, signal; os.kill(os.getpid(), signal.SIGKILL)'

# Always test the default timing backend.
# On macOS, also test the GNU time backend enabled by --gtime.
all: run_plain
	@if [[ "$$(uname)" == "Darwin" ]]; then \
		$(MAKE) run_gtime; \
	fi

# Tests the default backend without --gtime.
# Verifies three things:
# 1. galitime itself exits with status 137
# 2. the TSV output records the expected exit code
# 3. stderr contains the expected error message
run_plain:
	@set +e; \
	$(GALITIME) --log stdout "$(CMD)" > out.tsv 2> err.txt; \
	status=$$?; \
	set -e; \
	[[ "$$status" -eq 137 ]] || { \
		echo "ERROR: expected exit status 137, got $$status"; \
		exit 1; \
	}; \
	./check_exit_code.py out.tsv; \
	grep -q 'Galitime error: non-zero exit code (137)' err.txt

# Tests the --gtime backend on macOS.
# Verifies the same three things as run_plain, but through GNU time.
run_gtime: check_gtime
	@set +e; \
	$(GALITIME) --gtime --log stdout "$(CMD)" > out_gtime.tsv 2> err_gtime.txt; \
	status=$$?; \
	set -e; \
	[[ "$$status" -eq 137 ]] || { \
		echo "ERROR: expected exit status 137 with --gtime, got $$status"; \
		exit 1; \
	}; \
	./check_exit_code.py out_gtime.tsv; \
	grep -q 'Galitime error: non-zero exit code (137)' err_gtime.txt

# Preconditions for the macOS-specific --gtime test.
# Ensures GNU time is installed and available in PATH.
check_gtime:
	@command -v gtime >/dev/null || { \
		echo "ERROR: gtime not found in PATH"; \
		echo "Install it with: brew install gnu-time"; \
		exit 1; \
	}

# Remove test artifacts generated by both backends.
clean:
	rm -f out.tsv out_gtime.tsv err.txt err_gtime.txt

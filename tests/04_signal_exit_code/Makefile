.PHONY: all clean test_plain_signal_exit_code test_gtime_signal_exit_code

SHELL := /usr/bin/env bash
.SHELLFLAGS := -eo pipefail -c

# CLI under test.
GALITIME := ../../galitime

# Command that kills itself with SIGKILL.
# On Unix shells, this should surface as exit status 137 = 128 + 9.
CMD := python3 -c 'import os, signal; os.kill(os.getpid(), signal.SIGKILL)'

UNAME_S := $(shell uname -s)

# Always test the default backend.
# On macOS, also test the GNU time backend enabled by --gtime.
TEST_TARGETS := test_plain_signal_exit_code
TOTAL_STEPS := 1

ifeq ($(UNAME_S),Darwin)
TEST_TARGETS += test_gtime_signal_exit_code
TOTAL_STEPS := 2
endif

# Run the backend-specific signal-preservation checks.
all: $(TEST_TARGETS)

# Ensure GNU time is available for macOS-specific --gtime tests.
define ASSERT_GTIME_AVAILABLE
	@command -v gtime >/dev/null || { \
		echo "ERROR: gtime not found in PATH"; \
		echo "Install it with: brew install gnu-time"; \
		exit 1; \
	}
endef

# Check the default backend.
# Verifies three things:
# 1. galitime exits with status 137
# 2. the TSV output records exit_code 137
# 3. stderr reports the non-zero exit code
test_plain_signal_exit_code:
	@echo "[1/$(TOTAL_STEPS)] Default backend signal exit-code check"
	@set +e; \
	$(GALITIME) --log stdout "$(CMD)" > out.tsv 2> err.txt; \
	status=$$?; \
	set -e; \
	[[ "$$status" -eq 137 ]] || { \
		echo "ERROR: expected exit status 137, got $$status"; \
		exit 1; \
	}; \
	./check_exit_code.py out.tsv; \
	grep -q 'Galitime error: non-zero exit code (137)' err.txt

# Check the GNU time backend on macOS.
# Verifies the same three things as the default backend test.
test_gtime_signal_exit_code:
	@echo "[2/$(TOTAL_STEPS)] GNU time backend signal exit-code check"
	$(call ASSERT_GTIME_AVAILABLE)
	@set +e; \
	$(GALITIME) --gtime --log stdout "$(CMD)" > out_gtime.tsv 2> err_gtime.txt; \
	status=$$?; \
	set -e; \
	[[ "$$status" -eq 137 ]] || { \
		echo "ERROR: expected exit status 137 with --gtime, got $$status"; \
		exit 1; \
	}; \
	./check_exit_code.py out_gtime.tsv ; \
	grep -q 'Galitime error: non-zero exit code (137)' err_gtime.txt

# Remove files generated by both backend checks.
clean:
	rm -f out.tsv out_gtime.tsv err.txt err_gtime.txt
